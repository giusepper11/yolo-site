# Client-visible canonical URL
NEXT_PUBLIC_SITE_URL=https://example.com

# Ollama Cloud server-side configuration (do NOT expose the API key client-side)
# Note: OpenRouter variables are no longer required for the digital twin chat feature.
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_TIMEOUT_MS=20000
OLLAMA_MAX_INPUT_CHARS=1200
OLLAMA_MAX_OUTPUT_TOKENS=500
OLLAMA_MAX_CONTEXT_CHARS=7500
OLLAMA_APP_URL=https://example.com
OLLAMA_APP_TITLE=Career Digital Twin
